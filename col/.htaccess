# col/.htaccess
# 启用 Rewrite
RewriteEngine On
# 确保 col 目录下的相对路径资源正常加载
RewriteBase /col/

# 解决 MD 文件访问（确保 fetch(id).md 能正确指向 col 目录下的 MD 文件）
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} ^/col/([0-9]+)\.md$
RewriteRule ^(.*)$ /col/$1.md [L]

# 静态资源缓存（可选）
<FilesMatch "\.(jpg|jpeg|png|gif|svg|css|js|md)$">
    ExpiresActive On
    ExpiresDefault "access plus 1 days"
</FilesMatch>
